// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false) @map("email_verified")
  image         String?
  password      String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sessions        Session[]
  accounts        Account[]
  workoutPlans    WorkoutPlan[]
  workoutSessions WorkoutSession[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@map("accounts")
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  @@map("verifications")
}

model WorkoutPlan {
  id          String       @id @default(uuid())
  name        String
  userId      String       @map("user_id")
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  isActive    Boolean      @default(true) @map("is_active")
  workoutDays WorkoutDay[]
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("workout_plans")
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model WorkoutDay {
  id                         String            @id @default(uuid())
  name                       String
  workoutPlanId              String            @map("workout_plan_id")
  workoutPlan                WorkoutPlan       @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  isRest                     Boolean           @default(false) @map("is_rest")
  weekday                    Weekday
  estimatedDurationInSeconds Int               @default(0) @map("estimated_duration_in_seconds")
  workoutExercises           WorkoutExercise[]
  workoutSessions            WorkoutSession[]
  createdAt                  DateTime          @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                  DateTime          @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("workout_days")
}

model WorkoutExercise {
  id                String     @id @default(uuid())
  name              String
  workoutDayId      String     @map("workout_day_id")
  workoutDay        WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  order             Int
  sets              Int        @default(1)
  reps              Int
  restTimeInSeconds Int        @map("rest_time_in_seconds")
  createdAt         DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime   @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("workout_exercises")
}

model WorkoutSession {
  id           String     @id @default(uuid())
  workoutDayId String     @map("workout_day_id")
  workoutDay   WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  userId       String     @map("user_id")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt    DateTime   @map("started_at") @db.Timestamptz()
  completedAt  DateTime?  @map("completed_at") @db.Timestamptz()
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("workout_sessions")
}
